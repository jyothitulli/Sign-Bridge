{
  "name": "signbridge",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "backend": "npm run dev --prefix backend",
    "backend:install": "npm install --prefix backend",
    "smoke": "node scripts/smoke-check.mjs",
    "train:demo": "python training/export_builtin_templates.py && python training/train_tcn.py --data training/exports/builtin_demo.json --output public/models/lstm --epochs 50 --min-samples 1",
    "download:wlasl": "python training/download_wlasl.py",
    "train:wlasl:json": "python training/prepare_from_wlasl.py --download-json --videos-dir data/kaggle",
    "train:public": "python training/train_public.py --download-json --videos-dir training/data/kaggle",
    "train:wlasl": "python training/train_public.py --download-json --videos-dir training/data/kaggle",
    "train:tcn": "python training/train_tcn.py --data training/exports/merged.json --output public/models/lstm",
    "train:lstm": "python training/train_lstm.py --data training/exports/merged.json --output public/models/lstm",
    "train:gloss2en": "python training/prepare_gloss2en.py && python training/build_gloss2en_index.py",
    "train:continuous": "python training/prepare_continuous_gloss.py && python training/train_gloss_ctc.py",
    "train:continuous:prepare": "python training/prepare_continuous_gloss.py",
    "setup:training": "python training/setup_env.py",
    "setup:training:base": "python -m pip install -r training/requirements-base.txt",
    "export:tfjs": "python training/export_tfjs_quantized.py --keras-dir public/models/lstm --output public/models/lstm --quantize uint8"
  },
  "dependencies": {
    "@mediapipe/camera_utils": "^0.3.1675466862",
    "@mediapipe/drawing_utils": "^0.3.1675466124",
    "@mediapipe/holistic": "^0.5.1675471629",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toast": "^1.2.15",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tensorflow/tfjs": "^4.22.0",
    "@types/three": "^0.184.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "idb": "^8.0.3",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0",
    "three": "^0.184.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "typescript": "5.9.3"
  }
}
