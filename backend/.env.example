# Copy to .env and fill in your MongoDB Atlas connection string
PORT=4000
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/signbridge?retryWrites=true&w=majority
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_REFRESH_SECRET=change-this-refresh-secret-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_DAYS=7
CORS_ORIGIN=http://localhost:3000
